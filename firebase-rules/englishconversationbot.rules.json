{
  "rules": {
    ".read": false,
    ".write": false,

    "searchLogs": {
      ".read": true,
      "$year": {
        "$month": {
          "$day": {
            "$logId": {
              ".write": true,
              ".validate": "newData.hasChildren(['query', 'deviceId', 'timestamp'])"
            }
          }
        }
      }
    },

    "aiChatLogs": {
      ".read": true,
      "$year": {
        "$month": {
          "$day": {
            "$logId": {
              ".write": true,
              ".validate": "newData.hasChildren(['userMessage', 'deviceId', 'timestamp'])"
            }
          }
        }
      }
    },

    "flaggedSearches": {
      ".read": true,
      "$year": {
        "$month": {
          "$day": {
            "$logId": {
              ".write": true,
              ".validate": "newData.hasChildren(['query', 'deviceId', 'reason', 'timestamp'])"
            }
          }
        }
      }
    },

    "deviceRegistry": {
      ".read": true,
      "$deviceId": {
        ".write": true
      }
    },

    "users": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    }
  }
}
